def findUnion(self, a, b):
    # code here 
    
    i,j=0,0
    result = []
    val = 0
    while i<len(a) or j<len(b):
        if i<len(a) and (j == len(b) or a[i]<=b[j]):
            val = a[i]
            i+=1
        else:
            val = b[j]
            j+=1
        
        if not result or result[-1] != val:
            result.append(val)
                
    return result
