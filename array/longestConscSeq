def longestConsecutive(self, nums: List[int]) -> int:
    setnums = set(nums)
    n = len(setnums)
    maxcount = 0

    for num in setnums:
        if num-1 not in setnums:
            count=1
            nextnum = num+1
            while nextnum in setnums:
                count+=1
                nextnum+=1
            maxcount = max(count, maxcount)
            
    return maxcount
