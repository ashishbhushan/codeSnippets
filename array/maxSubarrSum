def maxSubArray(self, nums: List[int]) -> int:
    total = 0
    n = len(nums)
    # maxsum = float("-inf")
    # for i in range(n):
    #     for j in range(i,n):
    #         total+=nums[j]
    #         maxsum = max(total, maxsum)
    #     total = 0
    # return maxsum
    
    # kadanes algo - max subarray sum
    currsum = maxsum = nums[0]
    for i in range(1,n):
        currsum = max(nums[i], currsum+nums[i])
        maxsum = max(currsum, maxsum)
    return maxsum
